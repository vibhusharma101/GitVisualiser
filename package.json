{
  "name": "git-visualiser",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "git-3d": "./dist-server/index.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "package": "npm run build && pkg . --targets node18-win-x64 --output git-3d.exe"
  },
  "dependencies": {
    "@react-three/drei": "^9.88.16",
    "@react-three/fiber": "^8.15.11",
    "@react-three/postprocessing": "^2.15.11",
    "chokidar": "^3.5.3",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "framer-motion": "^10.16.4",
    "framer-motion-3d": "^10.16.4",
    "lucide-react": "^0.292.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "simple-git": "^3.21.0",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "three": "^0.158.0",
    "three-stdlib": "^2.28.7",
    "zustand": "^4.4.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.16",
    "@types/express": "^4.17.21",
    "@types/node": "^20.9.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@types/three": "^0.158.3",
    "@vitejs/plugin-react": "^4.2.0",
    "pkg": "^5.8.1",
    "tsx": "^4.1.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.0"
  },
  "pkg": {
    "assets": [
      "dist/**/*"
    ],
    "outputPath": "bin"
  }
}
